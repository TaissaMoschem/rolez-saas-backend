generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model categorias {
  id   Int    @id @default(autoincrement())
  nome String @db.VarChar(100)
}

model lanchonetes {
  id                 Int       @id @default(autoincrement())
  nome               String    @db.VarChar(100)
  email              String    @unique @db.VarChar(100)
  telefone           String?   @db.VarChar(20)
  cnpj               String?   @unique @db.VarChar(20)
  estilo_atendimento String?
  created_at         DateTime? @default(now()) @db.Timestamp(6)
}

model mesas {
  id     Int     @id @default(autoincrement())
  numero Int     @unique
  status String? @default("livre") @db.VarChar(20)

  pedidos pedidos[]
}

model pedidos {
  id         Int      @id @default(autoincrement())
  mesa_id    Int
  status     String   @default("aberto") @db.VarChar(20)
  created_at DateTime @default(now()) @db.Timestamp(6)

  mesa mesas @relation(fields: [mesa_id], references: [id])
}